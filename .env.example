# Ledger Secure Platform — environment template (copy to .env.local)

# 32+ char random strings — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

LEDGER_JWT_SECRET=replace-with-32-byte-random-string-please
LEDGER_INTERNAL_KEY=replace-with-another-32-byte-random-string

# Service ports (defaults match scripts/start-all.ts)
LEDGER_FRONTEND_PORT=5110
LEDGER_LEDGER_PORT=5111
LEDGER_PAYMENTS_PORT=5112
LEDGER_FX_PORT=5113
LEDGER_RECONCILIATION_PORT=5114
LEDGER_FRAUD_PORT=5115
LEDGER_WEBHOOK_PORT=5116

# Broker poll cadence (ms)
LEDGER_BROKER_POLL_MS=200

# Webhook delivery worker
LEDGER_WEBHOOK_MAX_ATTEMPTS=8
